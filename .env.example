TMDB_API_KEY=your_tmdb_api_key_here

# Vercel Postgres - these are auto-provided when you link a Vercel Postgres database.
# For local development, copy the values from your Vercel project settings.
POSTGRES_URL=postgres://user:password@host/dbname
POSTGRES_URL_NON_POOLING=postgres://user:password@host/dbname
