{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/auth",
      "destination": "/api/auth/[...path]?path=__root__"
    },
    {
      "source": "/api/auth/:path*",
      "destination": "/api/auth/[...path]?path=:path*"
    },
    {
      "source": "/api/dashboard",
      "destination": "/api/dashboard/[...path]?path=__root__"
    },
    {
      "source": "/api/dashboard/:path*",
      "destination": "/api/dashboard/[...path]?path=:path*"
    },
    {
      "source": "/dashboard-selection",
      "destination": "/index.html"
    },
    {
      "source": "/dashboard-selection/",
      "destination": "/index.html"
    },
    {
      "source": "/dashboard/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/login",
      "destination": "/index.html"
    },
    {
      "source": "/login/",
      "destination": "/index.html"
    },
    {
      "source": "/privacy-policy",
      "destination": "/index.html"
    },
    {
      "source": "/privacy-policy/",
      "destination": "/index.html"
    },
    {
      "source": "/terms-of-service",
      "destination": "/index.html"
    },
    {
      "source": "/terms-of-service/",
      "destination": "/index.html"
    },
    {
      "source": "/report-a-bug",
      "destination": "/index.html"
    },
    {
      "source": "/report-a-bug/",
      "destination": "/index.html"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
