{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/shelf",
      "destination": "/api/shelf/[...path]?path=__root__"
    },
    {
      "source": "/api/shelf/:path*",
      "destination": "/api/shelf/[...path]?path=:path*"
    },
    {
      "source": "/shelf-selection",
      "destination": "/index.html"
    },
    {
      "source": "/shelf-selection/",
      "destination": "/index.html"
    },
    {
      "source": "/shelf/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/login",
      "destination": "/index.html"
    },
    {
      "source": "/login/",
      "destination": "/index.html"
    },
    {
      "source": "/privacy-policy",
      "destination": "/index.html"
    },
    {
      "source": "/privacy-policy/",
      "destination": "/index.html"
    },
    {
      "source": "/terms-of-service",
      "destination": "/index.html"
    },
    {
      "source": "/terms-of-service/",
      "destination": "/index.html"
    },
    {
      "source": "/report-a-bug",
      "destination": "/index.html"
    },
    {
      "source": "/report-a-bug/",
      "destination": "/index.html"
    }
  ]
}
